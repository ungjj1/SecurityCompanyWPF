<Window x:Class="SecurityCompany.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SecurityCompany"
        mc:Ignorable="d"
        Background="#162033"
        Title="Главная" Height="800" Width="1200" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#162033"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                            CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                        VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#38BDF8"/>
                    <Setter Property="Foreground" Value="#162033"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        
        <!--Верхняя панель-->
        <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="2">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="ГАРД" Foreground="White" FontSize="16" FontWeight="DemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Охранное предприятие" Foreground="White" FontSize="16" FontWeight="DemiBold"/>
            </StackPanel>
            <Button x:Name="BtnExit" Content="Выйти" HorizontalAlignment="Right" VerticalAlignment="Center" Click="BtnExit_Click"  Style="{StaticResource HoverButtonStyle}" FontWeight="DemiBold"
                 Height="40" Margin="0 10 10 0" 
                 Foreground="White" Width="100" BorderThickness="0"/>   
        </Grid>
        <!--Логотип-->
        <StackPanel Grid.Column="0" Grid.Row="0" Grid.RowSpan="2">
            <Image Source="/Resources/logowithout.png" Height="100"/>
        </StackPanel>
        <!--Боковая панель-->
        <StackPanel Grid.Column="0" Grid.Row="2" Background="#162033">
            <Button Content="Клиенты" Name="BtnCLient" Click="BtnClient_Click" 
                Style="{StaticResource HoverButtonStyle}" FontWeight="DemiBold"
                Height="40" Margin="5 10 5 0" 
                Foreground="White" Width="200" BorderThickness="0"/>
            <Button Content="Штат" Name="BtnEmployees" Click="BtnEmployees_Click"
                Style="{StaticResource HoverButtonStyle}" FontWeight="DemiBold"
                Height="40" Margin="5 10 5 0" 
                Foreground="White" Width="200" BorderThickness="0"/>
            <Button Content="Объекты" Name="BtnObject" Click="BtnObject_Click"
                Style="{StaticResource HoverButtonStyle}" FontWeight="DemiBold"
                Height="40" Margin="5 10 5 0" 
                Foreground="White" Width="200" BorderThickness="0"/>   
        </StackPanel>
        <!--Низняя панель с администратором-->
        <StackPanel Grid.Column="0" Grid.Row="3">
            <TextBlock Foreground="White" FontSize="12" Name="TBUserName" HorizontalAlignment="Center" Margin="5 0"/>
            <TextBlock FontSize="10" Foreground="#6492AE" Name="TBRole" HorizontalAlignment="Center" />
        </StackPanel>
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Grid.Column="1" Grid.Row="2" Grid.RowSpan="3" Margin="10" Background="White"></Frame>
    </Grid>
</Window>
