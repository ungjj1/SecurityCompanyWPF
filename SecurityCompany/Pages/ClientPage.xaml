<Page x:Class="SecurityCompany.Pages.ClientPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SecurityCompany.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ClientPage">
    <Page.Resources>
        <local:ImageConverter x:Key="ImageConverter"/>
        <DataTemplate x:Key="ClientTemplate">
            <Border Margin="0 5" Padding="10" Height="140" BorderBrush="LightGray" BorderThickness="1" Background="Transparent" MouseLeftButtonUp="Border_MouseLeftButtonUp">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="20 0 0 0">
                        <TextBlock Foreground="White" FontWeight="Bold" Text="{Binding NameCompany, StringFormat='Название компании: {0}'}"/>
                        <TextBlock Foreground="White" FontSize="12" x:Name="TxtNameObject"/>
                        <TextBlock Foreground="White" FontSize="12" x:Name="TxtAdressObject"/>
                        <TextBlock Foreground="White" FontSize="12" Text="{Binding ContractNumber, StringFormat='Контракт: {0}'}"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnDeleteClient" Click="BtnDeleteClient_Click" Content="Расторгнуть договор" Style="{StaticResource HoverButtonStyle}" FontWeight="DemiBold"
                        Foreground="White" Height="30" Width="120"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel x:Name="TopPanel" HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0">
            <Label Content="Поиск:" Foreground="White"/>
            <TextBox Width="175" Name="TBSearch" FontSize="20" TextChanged="TBSearch_TextChanged" VerticalAlignment="Center" Height="30" Background="#162033" Foreground="White" BorderBrush="#324055" SelectionChanged="TBSearch_SelectionChanged">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
            <Label Content="Сортировка:" Foreground="white"/>
            <ComboBox x:Name="SortComboBox" SelectedItem="0" Width="150" SelectionChanged="SortComboBox_SelectionChanged"/>
            <Button x:Name="BtnCreateClient"  Content="Добавить клиента" Margin="10 0" Width="150"  Click="BtnCreateClient_Click"  Style="{StaticResource HoverButtonStyle}" FontWeight="DemiBold"
                 Height="30"
                 Foreground="White" />
            <Button Content="Отчёт" Name="BtnFullReport" Click="BtnFullReport_Click" Width="100" Style="{StaticResource HoverButtonStyle}" FontWeight="DemiBold" />
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ObjectList" ItemTemplate="{StaticResource ClientTemplate}"/>
        </ScrollViewer>
    </Grid>
</Page>
