<Page x:Class="SecurityCompany.Pages.EmployeePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SecurityCompany.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EmployeePage">
    <Page.Resources>
        <local:AvatarConverter x:Key="ImageConverter"/>
        <DataTemplate x:Key="EmployyeTemplate">
            <Border Margin="0 5" Padding="10" Height="140" BorderBrush="LightGray" BorderThickness="1" Background="Transparent" MouseLeftButtonUp="Border_MouseLeftButtonUp">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="100" Height="100" HorizontalAlignment="Left" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
                        <Image Source="{Binding Path=Avatar, Converter={StaticResource ImageConverter}}"/>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="20 0 0 0">
                        <TextBlock Foreground="White" FontWeight="Bold">
                            <Run Text="{Binding FirstName}"/>
                            <Run Text="{Binding SecondName}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Post, StringFormat='Должность: {0}'}" FontSize="12" Foreground="White"/>
                        <TextBlock Text="{Binding Status, StringFormat='Статус сотрудника: {0}'}" FontSize="12" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="FireEmployye" Content="Уволить сотрудника" Click="FireEmployee_Click" Width="150" Height="30" HorizontalAlignment="Right" Style="{StaticResource HoverButtonStyle}" FontWeight="DemiBold"
                        Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel x:Name="TopPanel" HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0">
            <Label Content="Поиск:" Foreground="White"/>
            <TextBox Width="250" Name="TBSearch" FontSize="20" TextChanged="TBSearch_TextChanged" VerticalAlignment="Center" Height="30" Background="#162033" Foreground="White" BorderBrush="#324055">
                <TextBox.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </TextBox.Resources>
            </TextBox>
            <Button x:Name="BtnCreateEmployye"  Content="Добавить клиента" Margin="10 0" Width="150"  Click="BtnCreateEmployye_Click" Style="{StaticResource HoverButtonStyle}" FontWeight="DemiBold"
                 Height="30"
                 Foreground="White" />
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EmployyeList" ItemTemplate="{StaticResource EmployyeTemplate}"/>
        </ScrollViewer>
    </Grid>
</Page>
