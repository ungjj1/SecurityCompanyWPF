<Page x:Class="SecurityCompany.Pages.EmployeePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SecurityCompany.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EmployeePage">
    <Page.Resources>
        <local:ImageConverter x:Key="ImageConverter"/>
        <DataTemplate x:Key="EmployyeTemplate">
            <Border Margin="0 5" Padding="10" Height="140" BorderBrush="LightGray" BorderThickness="1" Background="Transparent" MouseLeftButtonUp="Border_MouseLeftButtonUp">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="74"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Width="100" Height="100" HorizontalAlignment="Left" Source="{Binding Path=Avatar, Converter={StaticResource ImageConverter}}"/>
                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="10 0 0 0">
                        <TextBlock Foreground="Black" FontWeight="Bold">
                            <Run Text="{Binding FirstName}"/>
                            <Run Text="{Binding SecondName}"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Post, StringFormat='Должность: {0}'}" FontSize="12"/>
                        <TextBlock Text="{Binding Status, StringFormat='Статус сотрудника: {0}'}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Grid.Column="2">
                        <Button x:Name="EditEmloyyeInfo" Content="Редактировать" Click="EditEmloyyeInfo_Click"/>
                        <Button x:Name="FireEmployye" Content="Уволить сотрудника" Click="FireEmployye_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel x:Name="TopPanel" HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Center" Grid.Row="0">
            <Label Content="Поиск:"/>
            <TextBox Width="250" Name="TBSearch" TextChanged="TBSearch_TextChanged" VerticalAlignment="Center"/>
            <Button x:Name="BtnCreateEmployye"  Content="Добавить клиента" Margin="10 0" Width="150" Click="BtnCreateEmployye_Click"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EmployyeList" ItemTemplate="{StaticResource EmployyeTemplate}"/>
        </ScrollViewer>
    </Grid>
</Page>
